# Public configuration — anything prefixed with NEXT_PUBLIC_ is exposed to the browser.

# Base URL for the FastAPI backend (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# Optional override for the AI route prefix. Defaults to ${API_V1_PREFIX}/ai when unset.
NEXT_PUBLIC_AI_BASE_URL=

# Request timeouts (milliseconds).
NEXT_PUBLIC_API_TIMEOUT_MS=20000
NEXT_PUBLIC_AI_TIMEOUT_MS=60000

# Upload limits — enforced client-side for fast feedback. Must match backend.
NEXT_PUBLIC_MAX_UPLOAD_MB=10
NEXT_PUBLIC_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Feature flags.
NEXT_PUBLIC_ENABLE_GRADCAM=true
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_DEV_LOGS=true
