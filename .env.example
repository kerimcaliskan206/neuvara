# App
APP_NAME=HantaProject
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production

# API
API_V1_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hanta_user
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=hanta_db

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=NEURAVA <noreply@yourdomain.com>
FRONTEND_URL=https://yourdomain.com

# AI assistant (Groq — https://console.groq.com)
AI_ENABLED=true
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
AI_TEMPERATURE=0.2
AI_TOP_P=0.9
AI_MAX_TOKENS=512
AI_MAX_INPUT_CHARS=2000
AI_MAX_OUTPUT_CHARS=4000
AI_MAX_CONVERSATION_TURNS=8

# ML model loading
ML_AUTO_LOAD_ON_STARTUP=true
VISION_AUTO_LOAD_ON_STARTUP=true
